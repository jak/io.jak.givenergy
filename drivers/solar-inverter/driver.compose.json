{
  "name": { "en": "Solar Inverter" },
  "class": "solarpanel",
  "capabilities": [
    "measure_power",
    "meter_power",
    "grid_power",
    "load_power",
    "grid_import_energy",
    "grid_export_energy"
  ],
  "capabilitiesOptions": {
    "measure_power": {
      "title": { "en": "Solar Power" }
    },
    "meter_power": {
      "title": { "en": "Solar Energy" }
    }
  },
  "energy": {
    "meterPowerExportedCapability": "meter_power"
  },
  "platforms": ["local"],
  "connectivity": ["lan"],
  "images": {
    "small": "/drivers/solar-inverter/assets/images/small.jpg",
    "large": "/drivers/solar-inverter/assets/images/large.jpg",
    "xlarge": "/drivers/solar-inverter/assets/images/xlarge.jpg"
  },
  "pair": [
    {
      "id": "discover",
      "options": { "title": { "en": "Find Inverter" } }
    },
    {
      "id": "list_devices",
      "template": "list_devices",
      "navigation": { "next": "add_devices" },
      "options": { "singular": false }
    },
    {
      "id": "add_devices",
      "template": "add_devices"
    }
  ],
  "repair": [
    {
      "id": "repair"
    }
  ],
  "settings": [
    {
      "type": "group",
      "label": { "en": "Device Info" },
      "children": [
        { "id": "label_serial_number", "type": "label", "label": { "en": "Serial Number" }, "value": "-" },
        { "id": "label_generation", "type": "label", "label": { "en": "Generation" }, "value": "-" },
        { "id": "label_ip_address", "type": "label", "label": { "en": "IP Address" }, "value": "-" },
        { "id": "label_model_code", "type": "label", "label": { "en": "Model Code" }, "value": "-" }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Inverter Mode" },
      "children": [
        {
          "id": "inverter_mode",
          "type": "dropdown",
          "label": { "en": "Mode" },
          "value": "eco",
          "values": [
            { "id": "eco", "label": { "en": "Eco" } },
            { "id": "timed_demand", "label": { "en": "Timed Demand" } },
            { "id": "timed_export", "label": { "en": "Timed Export" } }
          ]
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Charge Schedule" },
      "children": [
        {
          "id": "charge_schedule_enabled",
          "type": "checkbox",
          "label": { "en": "Enable Charge Schedule" },
          "value": false
        },
        {
          "id": "charge_slot1_start",
          "type": "text",
          "label": { "en": "Charge Slot 1 Start (HH:MM)" },
          "value": "00:30"
        },
        {
          "id": "charge_slot1_end",
          "type": "text",
          "label": { "en": "Charge Slot 1 End (HH:MM)" },
          "value": "04:30"
        },
        {
          "id": "charge_slot1_target_soc",
          "type": "number",
          "label": { "en": "Charge Slot 1 Target SOC (%)" },
          "value": 100,
          "min": 0,
          "max": 100
        },
        {
          "id": "charge_rate",
          "type": "number",
          "label": { "en": "Charge Rate (W)" },
          "value": 2600,
          "min": 0,
          "max": 10000
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Discharge Schedule" },
      "children": [
        {
          "id": "discharge_schedule_enabled",
          "type": "checkbox",
          "label": { "en": "Enable Discharge Schedule" },
          "value": false
        },
        {
          "id": "discharge_slot1_start",
          "type": "text",
          "label": { "en": "Discharge Slot 1 Start (HH:MM)" },
          "value": "00:00"
        },
        {
          "id": "discharge_slot1_end",
          "type": "text",
          "label": { "en": "Discharge Slot 1 End (HH:MM)" },
          "value": "00:00"
        },
        {
          "id": "discharge_slot1_target_soc",
          "type": "number",
          "label": { "en": "Discharge Slot 1 Target SOC (%)" },
          "value": 0,
          "min": 0,
          "max": 100
        },
        {
          "id": "discharge_rate",
          "type": "number",
          "label": { "en": "Discharge Rate (W)" },
          "value": 2600,
          "min": 0,
          "max": 10000
        }
      ]
    },
    {
      "type": "group",
      "label": { "en": "Gen3 Features" },
      "children": [
        {
          "id": "export_limit",
          "type": "number",
          "label": { "en": "Export Limit (W)" },
          "hint": { "en": "Grid export limit in watts. Gen3 inverters only." },
          "value": 10000,
          "min": 0,
          "max": 10000
        },
        {
          "id": "battery_pause_mode",
          "type": "dropdown",
          "label": { "en": "Battery Pause Mode" },
          "hint": { "en": "Pause battery charge/discharge. Gen3 inverters only." },
          "value": "disabled",
          "values": [
            { "id": "disabled", "label": { "en": "Disabled (normal)" } },
            { "id": "pause_charge", "label": { "en": "Pause Charge" } },
            { "id": "pause_discharge", "label": { "en": "Pause Discharge" } },
            { "id": "pause_both", "label": { "en": "Pause Both" } }
          ]
        }
      ]
    }
  ]
}
