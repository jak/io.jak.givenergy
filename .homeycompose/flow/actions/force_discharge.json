      "max": 100,
      "step": 1,
      "value": 100
    },
    {
      "type": "number",
      "name": "battery_reserve",
      "title": { "en": "Battery Reserve (%)" },
      "min": 4,
      "max": 100,
      "step": 1,
      "value": 4
    }
  ]
}
