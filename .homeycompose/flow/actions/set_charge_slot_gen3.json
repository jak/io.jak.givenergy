{
  "title": {
    "en": "Set charge slot",
    "nl": "Laadslot instellen",
    "af": "Stel laaislot"
  },
  "titleFormatted": {
    "en": "Set charge slot [[slot]] to [[start_time]] - [[end_time]] at [[target_soc]]%",
    "nl": "Laadslot [[slot]] instellen op [[start_time]] - [[end_time]] bij [[target_soc]]%",
    "af": "Stel laaislot [[slot]] op [[start_time]] - [[end_time]] teen [[target_soc]]%"
  },
  "hint": {
    "en": "Configures a charge schedule slot with target SOC. Gen3 inverters support slots 1-3.",
    "nl": "Configureert een laadslot met doel-SOC. Gen3-omvormers ondersteunen slots 1-3.",
    "af": "Stel 'n laaislot op met teiken-SOC. Gen3-omsetters ondersteun slots 1-3."
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=solar-inverter&capabilities=inverter_gen3"
    },
    {
      "type": "dropdown",
      "name": "slot",
      "title": {
        "en": "Slot",
        "nl": "Slot",
        "af": "Slot"
      },
      "values": [
        {
          "id": "1",
          "label": {
            "en": "Slot 1",
            "nl": "Slot 1",
            "af": "Slot 1"
          }
        },
        {
          "id": "2",
          "label": {
            "en": "Slot 2",
            "nl": "Slot 2",
            "af": "Slot 2"
          }
        },
        {
          "id": "3",
          "label": {
            "en": "Slot 3",
            "nl": "Slot 3",
            "af": "Slot 3"
          }
        }
      ]
    },
    {
      "type": "text",
      "name": "start_time",
      "title": {
        "en": "Start Time (HH:MM)",
        "nl": "Starttijd (UU:MM)",
        "af": "Begintyd (UU:MM)"
      },
      "placeholder": {
        "en": "00:30",
        "nl": "00:30",
        "af": "00:30"
      }
    },
    {
      "type": "text",
      "name": "end_time",
      "title": {
        "en": "End Time (HH:MM)",
        "nl": "Eindtijd (UU:MM)",
        "af": "Eindtyd (UU:MM)"
      },
      "placeholder": {
        "en": "04:30",
        "nl": "04:30",
        "af": "04:30"
      }
    },
    {
      "type": "number",
      "name": "target_soc",
      "title": {
        "en": "Target SOC (%)",
        "nl": "Doel-SOC (%)",
        "af": "Teiken-SOC (%)"
      },
      "min": 0,
      "max": 100,
      "step": 1,
      "value": 100
    }
  ]
}
