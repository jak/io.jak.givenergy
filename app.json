  "flow": {
    "triggers": [
      {
        "title": {
          "en": "Battery SOC changed"
        },
        "titleFormatted": {
          "en": "Battery SOC changed to [[soc]]%"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=battery"
          }
        ],
        "tokens": [
          {
            "name": "soc",
            "type": "number",
            "title": {
              "en": "SOC (%)"
            }
          }
        ],
        "id": "battery_soc_changed"
      },
      {
        "title": {
          "en": "Battery started charging"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=battery"
          }
        ],
        "id": "battery_started_charging"
      },
      {
        "title": {
          "en": "Battery started discharging"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=battery"
          }
        ],
        "id": "battery_started_discharging"
      },
      {
        "title": {
          "en": "Grid frequency dropped below a value"
        },
        "titleFormatted": {
          "en": "Grid frequency dropped below [[frequency]]Hz"
        },
        "args": [
          {
            "name": "frequency",
            "type": "number",
            "title": {
              "en": "Frequency (Hz)"
            },
            "placeholder": {
              "en": "e.g. 49.5"
            },
            "min": 45,
            "max": 55,
            "step": 0.1
          }
        ],
        "id": "grid_frequency_dropped_below"
      },
      {
        "title": {
          "en": "Grid frequency rose above a value"
        },
        "titleFormatted": {
          "en": "Grid frequency rose above [[frequency]]Hz"
        },
        "args": [
          {
            "name": "frequency",
            "type": "number",
            "title": {
              "en": "Frequency (Hz)"
            },
            "placeholder": {
              "en": "e.g. 50.5"
            },
            "min": 45,
            "max": 55,
            "step": 0.1
          }
        ],
        "id": "grid_frequency_rose_above"
      },
      {
        "title": {
          "en": "Grid switched to exporting"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=solar-inverter"
          }
        ],
        "id": "grid_switched_to_exporting"
      },
      {
        "title": {
          "en": "Grid switched to importing"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=solar-inverter"
          }
        ],
        "id": "grid_switched_to_importing"
      },
      {
        "title": {
          "en": "Grid voltage dropped below a value"
        },
        "titleFormatted": {
          "en": "Grid voltage dropped below [[voltage]]V"
        },
        "args": [
          {
            "name": "voltage",
            "type": "number",
            "title": {
              "en": "Voltage (V)"
            },
            "placeholder": {
              "en": "e.g. 220"
            },
            "min": 100,
            "max": 260,
            "step": 1
          }
        ],
        "id": "grid_voltage_dropped_below"
      },
      {
        "title": {
          "en": "Grid voltage rose above a value"
        },
        "titleFormatted": {
          "en": "Grid voltage rose above [[voltage]]V"
        },
        "args": [
          {
            "name": "voltage",
            "type": "number",
            "title": {
